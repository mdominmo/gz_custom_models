<?xml version="1.0"?>
<model>
  <name>x500_4rangefinders</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>Manuel Dominguez</name>
    <email>mandominguez97@gmail.com</email>
  </author>
  <description>
    An x500 quadcopter with 4 rangefinder sensors (front, back, left, right)
    for horizontal obstacle avoidance. Each rangefinder is a single-beam
    gpu_lidar sensor simulating a LW20-class distance sensor.
  </description>
</model>
